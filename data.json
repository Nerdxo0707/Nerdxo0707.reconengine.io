140, 248, 0.15); border-color: rgba(129, 140, 248, 0.3); }         .tab-trigger.active { color: #818cf8; position: relative; }         .tab-trigger.active::after { content: ''; position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%); width: 4px; height: 4px; border-radius: 50%; background: #818cf8; }         #crosshair { display: none; width: 6px; height: 6px; border: 2px solid rgba(255, 255, 255, 0.5); border-radius: 50%; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; pointer-events: none; }         .is-fps #crosshair { display: block; }         .playing .editor-ui { display: none !important; }         input[type=range] { accent-color: #818cf8; }         .checkbox-custom { width: 1.1rem; height: 1.1rem; accent-color: #6366f1; cursor: pointer; border-radius: 4px; }         ::-webkit-scrollbar { width: 4px; }         ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 10px; }     </style> </head> <body class=\"editor-mode\">      <div id=\"crosshair\"></div>      <!-- Header -->     <header class=\"editor-ui fixed top-0 left-0 w-full h-16 flex items-center justify-between px-6 z-40 glass-dock border-t-0 border-x-0\">         <div class=\"flex items-center gap-8\">             <div class=\"flex items-center gap-2\">                 <div class=\"w-3 h-3 bg-indigo-500 rounded-full animate-pulse\"></div>                 <h1 class=\"text-white text-lg font-extrabold tracking-tighter uppercase\">RECON<span class=\"text-indigo-500 ml-1\">1.9.6</span></h1>             </div>             <nav class=\"flex gap-6\">                 <button onclick=\"switchTab('create')\" id=\"tab-create\" class=\"tab-trigger active text-[10px] font-bold uppercase tracking-widest\">Construct</button>                 <button onclick=\"switchTab('scene')\" id=\"tab-scene\" class=\"tab-trigger text-[10px] font-bold uppercase tracking-widest\">Logic</button>             </nav>         </div>          <div class=\"flex items-center gap-3\">             <div class=\"flex items-center gap-1 bg-zinc-900/80 p-1 rounded-full border border-white/5 mr-4\">                 <button onclick=\"exportProject()\" class=\"px-4 py-1.5 text-[10px] font-bold text-zinc-400 hover:text-white transition-colors\">EXPORT</button>                 <div class=\"w-px h-3 bg-white/10\"></div>                 <label class=\"px-4 py-1.5 text-[10px] font-bold text-zinc-400 hover:text-white transition-colors cursor-pointer\">                     IMPORT                     <input type=\"file\" id=\"import-input\" class=\"hidden\" accept=\".json\" onchange=\"importProject(event)\">                 </label>             </div>             <div class=\"flex items-center gap-2 bg-zinc-900 px-4 py-2 rounded-full border border-white/5\">                 <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">FPS Mode</span>                 <input type=\"checkbox\" id=\"game-fps-toggle\" class=\"checkbox-custom\" checked>             </div>             <button id=\"play-btn\" onclick=\"togglePlayMode()\" class=\"bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2 rounded-full text-xs font-bold shadow-lg shadow-indigo-500/20 transition-all\">                 <span id=\"play-text\">RUN ENGINE</span>             </button>         </div>     </header>      <!-- Toolbar -->     <aside class=\"editor-ui fixed left-6 top-1/2 -translate-y-1/2 w-14 flex flex-col gap-2 p-2 rounded-2xl glass-dock z-40\">         <button onclick=\"setTool('translate')\" id=\"tool-translate\" class=\"btn-tool active p-3 rounded-xl border border-transparent\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7l4-4m0 0l4 4m-4-4v18m0 0l-4-4m4 4l4-4\"></path></svg></button>         <button onclick=\"setTool('rotate')\" id=\"tool-rotate\" class=\"btn-tool p-3 rounded-xl border border-transparent\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15\"></path></svg></button>         <button onclick=\"setTool('scale')\" id=\"tool-scale\" class=\"btn-tool p-3 rounded-xl border border-transparent\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4\"></path></svg></button>         <div class=\"h-px bg-white/10 my-1\"></div>         <button onclick=\"deleteSelected()\" class=\"btn-tool p-3 rounded-xl hover:text-red-400\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path></svg></button>     </aside>      <!-- Sidebar Panel (Construct) -->     <main id=\"panel-create\" class=\"editor-ui fixed left-24 top-24 bottom-32 w-80 p-6 glass-dock rounded-3xl z-40 overflow-y-auto space-y-6\">         <section>             <h3 class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-3\">Geometric Primitives</h3>             <div class=\"grid grid-cols-2 gap-2\">                 <button onclick=\"addObject('box')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">CUBE</button>                 <button onclick=\"addObject('sphere')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">SPHERE</button>                 <button onclick=\"addObject('cylinder')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">CYLINDER</button>                 <button onclick=\"addObject('cone')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">CONE</button>                 <button onclick=\"addObject('torus')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">TORUS</button>                 <button onclick=\"addObject('capsule')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">CAPSULE</button>             </div>         </section>          <section>             <h3 class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-3\">Architectural</h3>             <div class=\"grid grid-cols-2 gap-2\">                 <button onclick=\"addObject('wall')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">WALL</button>                 <button onclick=\"addObject('stairs')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">STAIRS</button>                 <button onclick=\"addObject('pillar')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">PILLAR</button>                 <button onclick=\"addObject('floor_tile')\" class=\"bg-zinc-800/40 hover:bg-zinc-800 p-3 rounded-xl border border-white/5 text-[9px] font-bold\">TILE</button>             </div>         </section>          <section>             <h3 class=\"text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-3\">Special Entities</h3>             <div class=\"grid grid-cols-2 gap-2\">                 <button onclick=\"addObject('text')\" class=\"bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 p-3 rounded-xl border border-indigo-500/20 text-[9px] font-bold\">3D TEXT</button>                 <button onclick=\"addObject('light')\" class=\"bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 p-3 rounded-xl border border-amber-500/20 text-[9px] font-bold\">POINT LIGHT</button>                 <button onclick=\"addObject('spawn')\" class=\"bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 p-3 rounded-xl border border-emerald-500/20 text-[9px] font-bold\">SPAWN POINT</button>             </div>         </section>          <section>             <h3 class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4\">Hierarchy</h3>             <div id=\"hierarchy-list\" class=\"space-y-1\"></div>         </section>     </main>      <!-- Settings Panel (Logic/Behaviors) -->     <main id=\"panel-scene\" class=\"editor-ui hidden fixed left-24 top-24 bottom-32 w-80 p-6 glass-dock rounded-3xl z-40 overflow-y-auto space-y-8\">         <div id=\"settings-no-selection\" class=\"text-zinc-500 text-[10px] font-bold uppercase text-center mt-10\">Select an object to edit logic</div>         <div id=\"settings-content\" class=\"hidden space-y-8\">             <section>                 <h3 class=\"text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-2\">Selected Object</h3>                 <div id=\"settings-target-name\" class=\"bg-zinc-900 p-3 rounded-xl border border-white/5 text-xs font-mono text-zinc-300 truncate\">NONE</div>             </section>                          <section>                 <h3 class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4\">Behaviors</h3>                 <div class=\"space-y-3\">                     <div class=\"flex items-center justify-between p-3 bg-white/5 rounded-xl\">                         <span class=\"text-[10px] font-bold uppercase\">Physics Drag</span>                         <input type=\"checkbox\" id=\"behDraggable\" onchange=\"updateObjectProps()\" class=\"checkbox-custom\">                     </div>                     <div class=\"flex items-center justify-between p-3 bg-white/5 rounded-xl\">                         <span class=\"text-[10px] font-bold uppercase\">Hover Animation</span>                         <input type=\"checkbox\" id=\"behHover\" onchange=\"updateObjectProps()\" class=\"checkbox-custom\">                     </div>                 </div>             </section>              <section>                 <h3 class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4\">Scene Environment</h3>                 <div class=\"space-y-3\">                     <div class=\"flex flex-col gap-2\">                         <span class=\"text-[9px] font-bold uppercase text-zinc-600\">Ambient Exposure</span>                         <input type=\"range\" id=\"envAmbient\" min=\"0\" max=\"2\" step=\"0.1\" value=\"0.4\" oninput=\"updateEnvironment()\" class=\"w-full\">                     </div>                 </div>             </section>         </div>     </main>      <!-- Properties Dock -->     <footer id=\"bottom-dock\" class=\"editor-ui fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-6xl h-24 glass-dock rounded-3xl z-40 p-4 flex items-center justify-center\">         <div id=\"no-selection-hint\" class=\"text-zinc-600 text-[10px] uppercase font-bold tracking-widest\">Select an object to modify properties</div>         <div id=\"properties-grid\" class=\"hidden w-full flex items-center justify-between px-4\">             <div class=\"flex gap-8 items-center\">                 <div class=\"flex flex-col gap-1\">                     <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">Appearance</span>                     <input type=\"color\" id=\"objColor\" oninput=\"updateObjectProps()\" class=\"w-10 h-8 bg-transparent cursor-pointer rounded overflow-hidden\">                 </div>                                  <div id=\"text-props\" class=\"flex gap-6 items-center border-l border-white/10 pl-6 hidden\">                     <div class=\"flex flex-col gap-1\">                         <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">3D Content</span>                         <input type=\"text\" id=\"textValue\" placeholder=\"Hello...\" oninput=\"updateObjectProps()\" class=\"bg-zinc-900 border border-white/10 rounded px-2 py-1 text-xs text-white w-40 outline-none\">                     </div>                 </div>                  <div id=\"light-props\" class=\"flex gap-6 items-center border-l border-white/10 pl-6 hidden\">                     <div class=\"flex flex-col gap-1\">                         <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">Intensity</span>                         <input type=\"range\" id=\"lightIntensity\" min=\"0\" max=\"20\" step=\"0.1\" oninput=\"updateObjectProps()\" class=\"w-24\">                     </div>                 </div>                  <div id=\"physics-props\" class=\"flex gap-8 items-center border-l border-white/10 pl-8\">                     <div class=\"flex flex-col items-center gap-1\">                         <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">Gravity</span>                         <input type=\"checkbox\" id=\"phyEnabled\" onchange=\"updateObjectProps()\" class=\"checkbox-custom\">                     </div>                     <div class=\"flex flex-col items-center gap-1\">                         <span class=\"text-[9px] font-bold text-zinc-500 uppercase\">Solid</span>                         <input type=\"checkbox\" id=\"phyCollidable\" onchange=\"updateObjectProps()\" class=\"checkbox-custom\">                     </div>                 </div>             </div>             <div class=\"flex items-center gap-4 bg-zinc-900/50 p-2 px-6 rounded-2xl border border-white/5\">                  <span id=\"selection-label\" class=\"text-[10px] font-mono text-indigo-400 uppercase tracking-tighter\">OBJECT_NAME</span>             </div>         </div>     </footer>      <script>         let scene, camera, renderer, transformControl, orbitControls, fpControls, gridHelper, ambientLight;         let selectedObject = null;         let objects = [];         let isPlaying = false;         let clock = new THREE.Clock();         let spawnPoint = null;         let font = null;                  // Interaction         let draggingObject = null;         let dragPlane = new THREE.Plane();         let dragIntersection = new THREE.Vector3();         let dragOffset = new THREE.Vector3();         const raycaster = new THREE.Raycaster();         const mouse = new THREE.Vector2();          // Player Movement         let playerVelocity = new THREE.Vector3();         let moveState = { forward: false, backward: false, left: false, right: false };         const PLAYER_HEIGHT = 1.8;         const GRAVITY = -18.0;          function init() {             scene = new THREE.Scene();             scene.background = new THREE.Color(0x050507);                          // Fog for atmosphere             scene.fog = new THREE.FogExp2(0x050507, 0.015);              camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 2000);             camera.position.set(12, 8, 12);              renderer = new THREE.WebGLRenderer({ antialias: true });             renderer.setSize(window.innerWidth, window.innerHeight);             renderer.shadowMap.enabled = true;             renderer.shadowMap.type = THREE.PCFSoftShadowMap;             renderer.toneMapping = THREE.ReinhardToneMapping;             document.body.appendChild(renderer.domElement);              orbitControls = new THREE.OrbitControls(camera, renderer.domElement);             orbitControls.enableDamping = true;                          fpControls = new THREE.PointerLockControls(camera, document.body);             scene.add(fpControls.getObject());              transformControl = new THREE.TransformControls(camera, renderer.domElement);             transformControl.addEventListener('dragging-changed', (e) => orbitControls.enabled = !e.value);             scene.add(transformControl);              ambientLight = new THREE.AmbientLight(0xffffff, 0.4);             scene.add(ambientLight);                          const sun = new THREE.DirectionalLight(0xffffff, 0.8);             sun.position.set(30, 60, 30);             sun.castShadow = true;             sun.shadow.mapSize.width = 2048;             sun.shadow.mapSize.height = 2048;             scene.add(sun);              gridHelper = new THREE.GridHelper(100, 50, 0x1a1a1e, 0x0f0f12);             scene.add(gridHelper);              const fontLoader = new THREE.FontLoader();             fontLoader.load('https://threejs.org/examples/fonts/helvetiker_bold.typeface.json', (loadedFont) => {                 font = loadedFont;                 addObject('floor_tile', true);                 addObject('spawn');             });              window.addEventListener('resize', onResize);             document.addEventListener('mousedown', onMouseDown);             document.addEventListener('mousemove', onMouseMove);             document.addEventListener('mouseup', onMouseUp);             document.addEventListener('keydown', (e) => handleKey(e.code, true));             document.addEventListener('keyup', (e) => handleKey(e.code, false));              animate();         }          function addObject(type, isRoot = false, params = null) {             let geo, mat = new THREE.MeshStandardMaterial({ color: 0x818cf8, roughness: 0.6, metalness: 0.1 });             let mesh;              switch(type) {                 case 'box': geo = new THREE.BoxGeometry(2, 2, 2); break;                 case 'sphere': geo = new THREE.SphereGeometry(1.2, 32, 32); break;                 case 'cylinder': geo = new THREE.CylinderGeometry(1, 1, 3, 32); break;                 case 'cone': geo = new THREE.ConeGeometry(1.2, 2.5, 32); break;                 case 'torus': geo = new THREE.TorusGeometry(1.2, 0.4, 16, 100); break;                 case 'capsule': geo = new THREE.CapsuleGeometry(0.8, 1.5, 8, 16); break;                 case 'wall':                      geo = new THREE.BoxGeometry(6, 4, 0.5);                      mat.color.set(0x3f3f46);                     break;                 case 'pillar':                     geo = new THREE.CylinderGeometry(0.5, 0.5, 8, 16);                     mat.color.set(0x52525b);                     break;                 case 'stairs':                     const stairGroup = new THREE.Group();                     for(let i=0; i<8; i++) {                         const sGeo = new THREE.BoxGeometry(3, 0.4, 0.6);                         const sMesh = new THREE.Mesh(sGeo, mat.clone());                         sMesh.position.set(0, i * 0.4, i * 0.6);                         stairGroup.add(sMesh);                     }                     mesh = stairGroup;                     break;                 case 'floor_tile':                     geo = new THREE.BoxGeometry(100, 1, 100);                     mat.color.set(0x18181b);                     break;                 case 'text':                     if (!font) return;                     const textVal = params?.textValue || 'RECON';                     geo = new THREE.TextGeometry(textVal, { font: font, size: 2, height: 0.5 });                     geo.center();                     mesh = new THREE.Mesh(geo, mat);                     mesh.isText = true;                     mesh.textValue = textVal;                     break;                 case 'light':                      const l = new THREE.PointLight(0xffcc00, 8, 30);                     l.castShadow = true;                     geo = new THREE.SphereGeometry(0.3, 16, 16);                     mat = new THREE.MeshBasicMaterial({ color: 0xffcc00 });                     mesh = new THREE.Mesh(geo, mat);                     mesh.add(l);                     mesh.isLight = true;                     mesh.lightRef = l;                     break;                 case 'spawn':                     geo = new THREE.CylinderGeometry(1.2, 1.2, 0.2, 32);                     mat = new THREE.MeshBasicMaterial({ color: 0x10b981, transparent: true, opacity: 0.4 });                     mesh = new THREE.Mesh(geo, mat);                     mesh.isSpawn = true;                     if (spawnPoint) {                         scene.remove(spawnPoint);                         objects = objects.filter(o => o !== spawnPoint);                     }                     spawnPoint = mesh;                     break;             }              if (!mesh) mesh = new THREE.Mesh(geo, mat);                          // Standardizing for group handling             const isGroup = mesh instanceof THREE.Group;             const applySettings = (m) => {                 m.castShadow = !m.isLight && !m.isSpawn;                 m.receiveShadow = true;             };              if (isGroup) mesh.children.forEach(applySettings);             else applySettings(mesh);              mesh.typeId = type;              if (params) {                 mesh.name = params.name;                 mesh.position.set(params.pos.x, params.pos.y, params.pos.z);                 mesh.rotation.set(params.rot.x, params.rot.y, params.rot.z);                 mesh.scale.set(params.scale.x, params.scale.y, params.scale.z);                 if (!isGroup && mesh.material.color) mesh.material.color.set(params.color);                 mesh.physics = params.physics;                 mesh.behaviors = params.behaviors;                 if (mesh.isLight) {                     mesh.lightRef.intensity = params.lightIntensity;                     mesh.lightRef.color.set(params.color);                 }             } else {                 mesh.name = type.toUpperCase() + \"_\" + Math.floor(Math.random()*999);                 mesh.position.set(0, type === 'floor_tile' ? -0.5 : 2, 0);                 mesh.physics = {                      enabled: false,                      collidable: !mesh.isLight && !mesh.isSpawn,                      isStatic: type === 'floor_tile' || mesh.isSpawn || type === 'wall' || type === 'stairs' || type === 'pillar',                      velocity: new THREE.Vector3(0, 0, 0),                      startPos: mesh.position.clone()                  };                 mesh.behaviors = { draggable: false, hover: false };             }                          scene.add(mesh);             objects.push(mesh);             refreshHierarchy();             if (!params) selectObject(mesh);             return mesh;         }          // --- EXPORT / IMPORT ---          function exportProject() {             const data = {                 version: \"1.9.6\",                 ambientIntensity: ambientLight.intensity,                 objects: objects.map(o => ({                     typeId: o.typeId,                     name: o.name,                     pos: { x: o.position.x, y: o.position.y, z: o.position.z },                     rot: { x: o.rotation.x, y: o.rotation.y, z: o.rotation.z },                     scale: { x: o.scale.x, y: o.scale.y, z: o.scale.z },                     color: (o.material && o.material.color) ? \"#\" + o.material.color.getHexString() : \"#ffffff\",                     physics: { ...o.physics, velocity: { x: 0, y: 0, z: 0 }, startPos: { x: o.position.x, y: o.position.y, z: o.position.z } },                     behaviors: o.behaviors,                     textValue: o.textValue || null,                     lightIntensity: o.isLight ? o.lightRef.intensity : null                 }))             };             const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });             const url = URL.createObjectURL(blob);             const a = document.createElement('a');             a.href = url;             a.download = `recon_v1.9.6_scene.json`;             a.click();             URL.revokeObjectURL(url);         }          function importProject(event) {             const file = event.target.files[0];             if (!file) return;             const reader = new FileReader();             reader.onload = (e) => {                 const data = JSON.parse(e.target.result);                 objects.forEach(o => scene.remove(o));                 objects = [];                 spawnPoint = null;                 selectObject(null);                 ambientLight.intensity = data.ambientIntensity || 0.4;                 data.objects.forEach(objData => addObject(objData.typeId, false, objData));                 refreshHierarchy();             };             reader.readAsText(file);         }          // --- CONTROLS ---          function selectObject(obj) {             if (isPlaying) return;             selectedObject = obj;             const hasSelection = !!obj;              document.getElementById('no-selection-hint').style.display = hasSelection ? 'none' : 'block';             document.getElementById('properties-grid').style.display = hasSelection ? 'flex' : 'none';             document.getElementById('settings-no-selection').style.display = hasSelection ? 'none' : 'block';             document.getElementById('settings-content').style.display = hasSelection ? 'block' : 'none';                          if (hasSelection) {                 document.getElementById('selection-label').innerText = obj.name;                 document.getElementById('settings-target-name').innerText = obj.name;                 if (obj.material && obj.material.color) {                     document.getElementById('objColor').value = \"#\" + obj.material.color.getHexString();                 }                 document.getElementById('phyEnabled').checked = obj.physics.enabled;                 document.getElementById('phyCollidable').checked = obj.physics.collidable;                 document.getElementById('behDraggable').checked = obj.behaviors.draggable;                 document.getElementById('behHover').checked = obj.behaviors.hover;                                  document.getElementById('light-props').classList.toggle('hidden', !obj.isLight);                 document.getElementById('text-props').classList.toggle('hidden', !obj.isText);                  if (obj.isLight) document.getElementById('lightIntensity').value = obj.lightRef.intensity;                 if (obj.isText) document.getElementById('textValue').value = obj.textValue;                 transformControl.attach(obj);             } else {                 transformControl.detach();             }             refreshHierarchy();         }          function updateObjectProps() {             if (!selectedObject) return;             const color = document.getElementById('objColor').value;             if (selectedObject.material && selectedObject.material.color) selectedObject.material.color.set(color);             selectedObject.physics.enabled = document.getElementById('phyEnabled').checked;             selectedObject.physics.collidable = document.getElementById('phyCollidable').checked;             selectedObject.behaviors.draggable = document.getElementById('behDraggable').checked;             selectedObject.behaviors.hover = document.getElementById('behHover').checked;              if (selectedObject.isLight) {                 selectedObject.lightRef.color.set(color);                 selectedObject.lightRef.intensity = parseFloat(document.getElementById('lightIntensity').value);             }              if (selectedObject.isText) {                 const newText = document.getElementById('textValue').value || ' ';                 if (newText !== selectedObject.textValue) {                     selectedObject.textValue = newText;                     selectedObject.geometry.dispose();                     selectedObject.geometry = new THREE.TextGeometry(newText, { font: font, size: 2, height: 0.5 });                     selectedObject.geometry.center();                 }             }         }          function updateEnvironment() {             ambientLight.intensity = parseFloat(document.getElementById('envAmbient').value);         }          function togglePlayMode() {             isPlaying = !isPlaying;             document.body.classList.toggle('playing', isPlaying);             const isFPS = document.getElementById('game-fps-toggle').checked;             document.body.classList.toggle('is-fps', isPlaying && isFPS);              if (isPlaying) {                 transformControl.detach();                 gridHelper.visible = false;                 objects.forEach(o => {                     o.physics.startPos = o.position.clone();                     if (o.isSpawn) o.visible = false;                 });                                  if (isFPS) {                     fpControls.lock();                     if (spawnPoint) {                         camera.position.copy(spawnPoint.position);                         camera.position.y += PLAYER_HEIGHT;                     } else {                         camera.position.set(0, PLAYER_HEIGHT, 0);                     }                     playerVelocity.set(0,0,0);                 }             } else {                 gridHelper.visible = true;                 if (fpControls.isLocked) fpControls.unlock();                 objects.forEach(o => {                     o.position.copy(o.physics.startPos);                     o.physics.velocity = new THREE.Vector3(0,0,0);                     if (o.isSpawn) o.visible = true;                 });                 selectObject(selectedObject);             }             document.getElementById('play-text').innerText = isPlaying ? \"TERMINATE (ESC)\" : \"BOOT ENGINE\";         }          // --- INPUT & PHYSICS ---          function onMouseDown(e) {             if (e.target.tagName !== 'CANVAS' || transformControl.dragging) return;             updateMouseCoords(e);             raycaster.setFromCamera(mouse, camera);             if (isPlaying) {                 const draggables = objects.filter(o => o.behaviors.draggable);                 const intersects = raycaster.intersectObjects(draggables, true);                 if (intersects.length > 0) {                     // Find parent if clicked part of a group                     let target = intersects[0].object;                     while(target.parent && target.parent !== scene) target = target.parent;                     draggingObject = target;                     const normal = new THREE.Vector3();                     camera.getWorldDirection(normal).negate();                     dragPlane.setFromNormalAndCoplanarPoint(normal, draggingObject.position);                     if (raycaster.ray.intersectPlane(dragPlane, dragIntersection)) dragOffset.copy(draggingObject.position).sub(dragIntersection);                 }             } else {                 const intersects = raycaster.intersectObjects(objects, true);                 if (intersects.length > 0) {                     let target = intersects[0].object;                     while(target.parent && target.parent !== scene) target = target.parent;                     selectObject(target);                 } else selectObject(null);             }         }          function onMouseMove(e) {             if (!isPlaying || !draggingObject) return;             updateMouseCoords(e);             raycaster.setFromCamera(mouse, camera);             if (raycaster.ray.intersectPlane(dragPlane, dragIntersection)) {                 draggingObject.position.lerp(dragIntersection.clone().add(dragOffset), 0.15);                 draggingObject.physics.velocity.set(0,0,0);             }         }          function onMouseUp() { draggingObject = null; }          function updateMouseCoords(e) {             mouse.x = (e.clientX / window.innerWidth) * 2 - 1;             mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;         }          function handleKey(code, isDown) {             if (code === 'Escape' && isPlaying) { togglePlayMode(); return; }             if (code === 'KeyW') moveState.forward = isDown;             if (code === 'KeyS') moveState.backward = isDown;             if (code === 'KeyA') moveState.left = isDown;             if (code === 'KeyD') moveState.right = isDown;             if (code === 'Space' && isDown && isPlaying) {                  if (Math.abs(playerVelocity.y) < 0