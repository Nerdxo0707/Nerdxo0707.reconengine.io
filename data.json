Pos.x = testPosX.x;                 let testPosZ = currentPos.clone().add(new THREE.Vector3(0, 0, moveDir.z));                 if (!checkCollision(testPosZ, 0.8)) currentPos.z = testPosZ.z;                  currentPos.y += playerVelocity.y * delta;                 if (currentPos.y < PLAYER_HEIGHT) { currentPos.y = PLAYER_HEIGHT; playerVelocity.y = 0; }                 fpControls.getObject().position.copy(currentPos);             }         }          function animate() {             requestAnimationFrame(animate);             let delta = Math.min(clock.getDelta(), 0.1);             if (isPlaying) updatePhysics(delta);             else orbitControls.update();             renderer.render(scene, camera);         }          function deleteSelected() {             if (!selectedObject || (selectedObject.physics.isStatic && selectedObject.typeId === 'floor_tile')) return;             if (selectedObject.isSpawn) spawnPoint = null;             scene.remove(selectedObject);             objects = objects.filter(o => o !== selectedObject);             selectObject(null);         }          function setTool(tool) {             transformControl.setMode(tool);             document.querySelectorAll('.btn-tool').forEach(b => b.classList.remove('active'));             document.getElementById('tool-'+tool).classList.add('active');         }          function refreshHierarchy() {             const list = document.getElementById('hierarchy-list');             list.innerHTML = \"\";             objects.forEach(obj => {                 const item = document.createElement('div');                 item.className = `text-[9px] p-2 px-3 rounded-lg cursor-pointer transition-all flex justify-between items-center ${selectedObject === obj ? 'bg-indigo-500/20 text-indigo-400 font-bold' : 'text-zinc-500 hover:bg-white/5'}`;                 item.innerHTML = `<span class=\"truncate pr-2\">${obj.name}</span> <span>${obj.isSpawn ? '📍' : ''}</span>`;                 item.onclick = () => selectObject(obj);